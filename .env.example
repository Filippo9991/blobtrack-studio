# Copia questo file in .env e compila i valori.
# In locale .env viene caricato da python-dotenv; in produzione le variabili
# vengono iniettate dalla piattaforma (Render).

# Chiave segreta Flask (genera con: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=

# Chiave API del provider LLM gratuito Groq (https://console.groq.com)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Ambiente: development | production | testing
FLASK_ENV=development

# Solo in produzione (Render lo fornisce automaticamente dal database PostgreSQL):
# DATABASE_URL=

# Limiti dell'elaborazione video (0 o assente = illimitato; in produzione
# i default sono 15s / 480px per il free tier — override qui se serve):
# VIDEO_MAX_SECONDS=15
# VIDEO_MAX_DIM=480
